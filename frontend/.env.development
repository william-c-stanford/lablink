# Development environment variables for LabLink frontend
# These are injected by Vite and available as import.meta.env.*

# Backend URL used by the Vite dev-server proxy.
# Change this if your FastAPI instance runs on a different host/port.
VITE_API_BASE_URL=http://localhost:8000

# Public base path for the app (leave empty for root)
VITE_BASE_URL=

# Feature flags
VITE_ENABLE_DEVTOOLS=true
