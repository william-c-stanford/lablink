# LabLink local development environment
# Copy this file: cp .env.example .env.local
# .env.local is gitignored — safe to add real secrets there.
# All variables shown here are the defaults for local SQLite dev mode.

# ------------------------------------------------------------------
# Database — defaults to SQLite (no Docker required)
# ------------------------------------------------------------------
LABLINK_DATABASE_URL=sqlite+aiosqlite:///./lablink.db

# ------------------------------------------------------------------
# Auth
# ------------------------------------------------------------------
LABLINK_SECRET_KEY=dev-secret-key-change-in-production
LABLINK_ACCESS_TOKEN_EXPIRE_MINUTES=30
LABLINK_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------
# Storage — defaults to local filesystem (no S3/MinIO required)
# ------------------------------------------------------------------
LABLINK_STORAGE_BACKEND=local
LABLINK_LOCAL_STORAGE_PATH=./storage

# ------------------------------------------------------------------
# Task execution — sync mode skips Celery/Redis entirely
# ------------------------------------------------------------------
LABLINK_TASK_BACKEND=sync

# ------------------------------------------------------------------
# Search — in-memory fallback (no Elasticsearch required)
# ------------------------------------------------------------------
LABLINK_SEARCH_BACKEND=memory

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
LABLINK_HOST=0.0.0.0
LABLINK_PORT=8000
LABLINK_DEBUG=true
LABLINK_LOG_LEVEL=info

# ------------------------------------------------------------------
# CORS — allows the Vite dev server
# ------------------------------------------------------------------
LABLINK_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------
# Optional: PostgreSQL / Redis / Elasticsearch for full-stack mode
# Uncomment and fill in if you want to run with Docker Compose.
# ------------------------------------------------------------------
# LABLINK_DATABASE_URL=postgresql+asyncpg://lablink:lablink@localhost:5432/lablink
# LABLINK_REDIS_URL=redis://localhost:6379/0
# LABLINK_ELASTICSEARCH_URL=http://localhost:9200
# LABLINK_TASK_BACKEND=celery
# LABLINK_SEARCH_BACKEND=elasticsearch
# LABLINK_STORAGE_BACKEND=s3
# LABLINK_AWS_ACCESS_KEY_ID=minioadmin
# LABLINK_AWS_SECRET_ACCESS_KEY=minioadmin
# LABLINK_AWS_S3_ENDPOINT_URL=http://localhost:9000
# LABLINK_AWS_S3_BUCKET=lablink
